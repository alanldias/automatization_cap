<mvc:View
  controllerName="telaaprovacaofi.aprovacaofi.controller.telaFI"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:core="sap.ui.core"
  displayBlock="true">

  <Page id="pageFi" showHeader="false">
    <VBox id="vboxPrincipal" width="100%">

      <!-- Cabeçalho -->
      <Toolbar id="toolbarCabecalho" height="3rem" class="cabecalhoTopo sapUiSmallMarginBottom">
        <HBox id="hboxCabecalho" width="100%" alignItems="Center" justifyContent="SpaceBetween">
          <HBox id="hboxLogo" alignItems="Center">
            <Image
              id="imgLogo"
              src="https://upload.wikimedia.org/wikipedia/commons/5/59/SAP_2011_logo.svg"
              height="2rem" width="auto"/>
          </HBox>
          <HBox id="hboxTitulo" width="98%" justifyContent="Center">
            <Text id="txtTitulo" text="Aprovação de Ordens de Produção — Financeiro (FI)" class="cabecalhoTexto"/>
          </HBox>
          <HBox id="hboxBtnAtualizar">
            <Button id="btnAtualizar" text="Atualizar" type="Ghost" icon="sap-icon://refresh" press=".onRefresh"/>
          </HBox>
        </HBox>
      </Toolbar>

      <!-- WRAPPER que centraliza -->
      <HBox id="hboxWrapperBoard" width="100%" justifyContent="Center">
        <!-- BOARD com 2 “cards” -->
        <f:GridContainer id="board"
                         snapToRow="false"
                         class="sapUiSmallMarginBegin sapUiSmallMarginEnd">
          <f:layout>
            <f:GridContainerSettings id="gridSettings" columnSize="100%" gap="0.3rem"/>
          </f:layout>

          <!-- CARD 1: Aguardando aprovação -->
          <Panel id="panelAguardando" headerText="Aguardando aprovação" class="sapUiResponsiveContentPadding">
            <layoutData>
              <f:GridContainerItemLayoutData id="layoutAguardando" columns="2"/>
            </layoutData>
            <headerToolbar>
              <Toolbar id="toolbarAguardando">
                <ToolbarSpacer id="spacerAguardandoEsq"/>
                <Title id="tituloAguardando" text="Aguardando aprovação" level="H4"/>
                <ToolbarSpacer id="spacerAguardandoDir"/>
              </Toolbar>
            </headerToolbar>

            <content>
              <VBox id="vboxTabelaAguardando" class="tableScrollShell">
                <Table id="tableOPAguard"
                       mode="SingleSelectMaster"
                       class="tabelaComBorda"
                       sticky="ColumnHeaders,InfoToolbar"
                       noDataText="Nenhuma ordem aguardando aprovação"
                       autoPopinMode="true"
                       popinLayout="GridSmall"
                       items="{
                         path: '/OrdensProducao',
                         parameters: {
                           $filter: 'status eq \'aguardando_aprovacao\'',
                           $orderby: 'createdAt asc, ID asc'
                         }
                       }">

                  <columns>
                    <Column id="colProdutoAguard" width="12rem" importance="High"><Text id="txtColProdutoAguard" text="Produto"/></Column>
                    <Column id="colQtdAguard" width="6rem" hAlign="Center" importance="Medium"><Text id="txtColQtdAguard" text="Quantidade"/></Column>
                    <Column id="colCentroCustoAguard" width="10rem" hAlign="Center" importance="Medium"><Text id="txtColCentroCustoAguard" text="Centro de Custo"/></Column>
                    <Column id="colStatusAguard" width="12rem" hAlign="Center" importance="Medium"><Text id="txtColStatusAguard" text="Status"/></Column>
                    <Column id="colDataAguard" importance="Low" hAlign="Center"><Text id="txtColDataAguard" text="Data de Criação"/></Column>
                    <Column id="colVincularAguard" width="14rem" importance="Low" hAlign="Center"/>
                    <Column id="colFuncoesAguard" width="7rem" importance="Low" hAlign="Center"><Text id="txtColFuncoesAguard" text="Funções"/></Column>
                    <Column id="colNegarAguard" width="6rem" importance="Low" hAlign="Center"/>
                  </columns>

                  <items>
                    <ColumnListItem id="itemAguard" type="Active" press=".onRowPressAguard" highlight="Warning">
                      <cells>
                        <ObjectIdentifier id="objProdutoAguard"
                          title="{produto_nome}"
                          text="{= ${produto_nome} }"
                          class="noWrap"
                          tooltip="{produto_nome}"/>

                        <ObjectNumber id="objQtdAguard" number="{quantidade}" emphasized="true"/>

                        <ObjectIdentifier id="objCentroCustoAguard"
                          title="{path: 'centroCusto_ID_ID'}"
                          text="{= ${centroCusto_ID_ID} ? ${centroCusto_ID_ID} : '— não vinculado —' }"
                          class="noWrap"
                          tooltip="{= ${centroCusto_ID_ID} ? ${centroCusto_ID_ID} : '— não vinculado —' }"
                          emptyIndicatorMode="On"/>

                        <ObjectStatus id="objStatusAguard" text="{status}" state="Warning" icon="sap-icon://pending"/>

                        <Text id="txtDataAguard" text="{= ${createdAt} || '' }" wrapping="false" maxLines="1"/>

                        <!-- Vincular CC -->
                        <Button id="btnVincularAguard" text="Vincular Centro de Custo" type="Ghost" icon="sap-icon://chain-link" press=".onVincularCC_Aguard">
                          <customData>
                            <core:CustomData id="dataVincularAguard" key="id" value="{ID}" writeToDom="false"/>
                          </customData>
                        </Button>

                        <!-- Aprovar -->
                        <Button id="btnAprovarAguard" text="Aprovar" icon="sap-icon://accept" type="Emphasized" press=".onAprovar_Aguard">
                          <customData>
                            <core:CustomData id="dataAprovarAguard" key="id" value="{ID}" writeToDom="false"/>
                          </customData>
                        </Button>

                        <!-- Negar -->
                        <Button id="btnNegarAguard" text="Negar" icon="sap-icon://decline" type="Reject" press=".onNegar_Aguard">
                          <customData>
                            <core:CustomData id="dataNegarAguard" key="id" value="{ID}" writeToDom="false"/>
                          </customData>
                        </Button>
                      </cells>
                    </ColumnListItem>
                  </items>
                </Table>
              </VBox>
            </content>
          </Panel>

          <!-- CARD 2: Ordens Negadas -->
          <Panel id="panelNegadas" headerText="Ordens Negadas" class="sapUiResponsiveContentPadding">
            <layoutData>
              <f:GridContainerItemLayoutData id="layoutNegadas" columns="1"/>
            </layoutData>
            <headerToolbar>
              <Toolbar id="toolbarNegadas">
                <ToolbarSpacer id="spacerNegadasEsq"/>
                <Title id="tituloNegadas" text="Ordens Negadas" level="H4"/>
                <ToolbarSpacer id="spacerNegadasDir"/>
              </Toolbar>
            </headerToolbar>

            <content>
              <VBox id="vboxTabelaNegadas" class="tableScrollShell">
                <Table id="tableOPNegada"
                       mode="SingleSelectMaster"
                       class="tabelaComBorda"
                       sticky="ColumnHeaders,InfoToolbar"
                       noDataText="Nenhuma ordem negada"
                       autoPopinMode="true"
                       popinLayout="GridSmall"
                       items="{
                         path: '/OrdensProducao',
                         parameters: {
                           $filter: 'status eq \'negado\'',
                           $orderby: 'modifiedAt desc, createdAt desc'
                         }
                       }">

                  <columns>
                    <Column id="colProdutoNegada" importance="High"><Text id="txtColProdutoNegada" text="Produto"/></Column>
                    <Column id="colQtdNegada" width="6rem" hAlign="Center" importance="Medium"><Text id="txtColQtdNegada" text="Quantidade"/></Column>
                    <Column id="colCentroCustoNegada" width="14rem" hAlign="Center" importance="Medium"><Text id="txtColCentroCustoNegada" text="Centro de Custo"/></Column>
                    <Column id="colStatusNegada" width="10rem" hAlign="Center" importance="Medium"><Text id="txtColStatusNegada" text="Status"/></Column>
                    <Column id="colMotivoNegada" importance="Low" hAlign="Center"><Text id="txtColMotivoNegada" text="Motivo da Negação"/></Column>
                    <Column id="colRevisaoNegada" width="10rem" hAlign="Center" importance="Medium"><Text id="txtColRevisaoNegada" text="Revisão"/></Column>
                  </columns>

                  <items>
                    <ColumnListItem id="itemNegada" type="Active" press=".onRowPressNegada" highlight="Error">
                      <cells>
                        <ObjectIdentifier id="objProdutoNegada"
                          title="{produto_nome}"
                          text="{= ${produto_nome} }"
                          class="noWrap"
                          tooltip="{produto_nome}"/>

                        <ObjectNumber id="objQtdNegada" number="{quantidade}" emphasized="true"/>

                        <ObjectIdentifier id="objCentroCustoNegada"
                          title="{path: 'centroCusto_ID_ID'}"
                          text="{= ${centroCusto_ID_ID} ? ${centroCusto_ID_ID} : '— não vinculado —' }"
                          emptyIndicatorMode="On"/>

                        <ObjectStatus id="objStatusNegada" text="{status}" state="Error" icon="sap-icon://status-negative"/>

                        <Text id="txtMotivoNegada" text="{= ${motivo} || '' }" wrapping="false" maxLines="1" tooltip="{motivo}"/>

                        <!-- Rever Ordem -->
                        <Button id="btnReverNegada" text="Rever Ordem" press=".onRever_Negada">
                          <customData>
                            <core:CustomData id="dataReverNegada" key="id" value="{ID}" writeToDom="false"/>
                          </customData>
                        </Button>
                      </cells>
                    </ColumnListItem>
                  </items>
                </Table>
              </VBox>
            </content>
          </Panel>

        </f:GridContainer>
      </HBox>

    </VBox>
  </Page>
</mvc:View>
