<mvc:View
    controllerName="vendas.controller.Cart"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

    <Page id="cartPage" title="Carrinho">
        <content>
            <List id="cartList" items="{ path: '/CarrinhoItem' }">
                <CustomListItem id="cartListItem">
                    <HBox id="cartHBox" alignItems="Center" justifyContent="SpaceBetween" class="cartItem">

                        <!-- Imagem -->
                        <Image
                            id="imgCartProduct"
                            src="{produto/imagem}"
                            width="80px"
                            height="80px"
                            densityAware="false"
                            decorative="false"
                            class="cartImage" />

                        <!-- Informações -->
                        <VBox id="cartVBox" class="sapUiSmallMarginBegin">
                            <Text id="txtCartProductName" text="{produto/nome}" class="cartProductName" />
                            <Text id="txtCartProductDesc" text="{produto/descricao}" wrapping="true" class="cartProductDesc" />
                            <ObjectNumber id="numCartProductPrice" number="{precoUnitario}" unit="R$" class="cartPrice" />
                            <Text id="txtCartQuantity" text="Qtd: {quantidade}" />
                        </VBox>

                        <!-- Botão Remover -->
                        <Button
                            id="btnRemoveFromCart"
                            icon="sap-icon://delete"
                            type="Reject"
                            class="btnRemove"
                            press=".onRemoveFromCart" />
                    </HBox>
                </CustomListItem>
            </List>
        </content>

        <footer>
            <Toolbar id="cartToolbar">
                <Text id="txtCartTotal" text="Total: R$ 0,00" class="cartPrice" />
                <ToolbarSpacer id="cartToolbarSpacer" />
                <Button id="btnCheckout" text="Finalizar Pedido" press=".onCheckout" type="Emphasized" />
            </Toolbar>
        </footer>
    </Page>
</mvc:View>
