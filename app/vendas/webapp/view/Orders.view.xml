<mvc:View
    controllerName="vendas.controller.Orders"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

    <Page id="ordersPage" showHeader="true" title="">

        <!-- Cabeçalho -->
        <customHeader>
            <Bar id="barOrdersHeader" design="Auto">
                <!-- Logo -->
                <contentLeft>
                    <Image
                        id="imgLogoOrders"
                        src="img/logo.png"
                        height="40px"
                        densityAware="false"
                        decorative="false" />
                </contentLeft>

                <!-- Título -->
                <contentMiddle>
                    <Title
                        id="titleOrdersHeader"
                        text="Meus Pedidos"
                        level="H2" />
                </contentMiddle>

                <!-- Botão voltar -->
                <contentRight>
                    <Button
                        id="btnBackToCatalogFromOrders"
                        icon="sap-icon://nav-back"
                        type="Transparent"
                        press=".onNavBack" />
                    <ToolbarSpacer id="spOrdersHeaderRight" />
                </contentRight>
            </Bar>
        </customHeader>

        <!-- Conteúdo -->
        <content>
            <List
                id="ordersList"
                inset="false"
                items="{ path: '/Pedidos' }">

                <!-- Cada pedido -->
                <CustomListItem
                    id="orderListItem"
                    type="Active"                
                    press=".onOpenDetail"       
                    class="orderItem">

                    <HBox id="orderHBox" alignItems="Center" justifyContent="SpaceBetween">

                        <!-- Informações -->
                        <VBox id="orderVBox" class="orderInfoBox">
                            <Text id="txtOrderID"
                                  text="Pedido #{ID}"
                                  class="orderIdText" />

                            <ObjectStatus id="statusOrder"
                                text="{status}"
                                state="{
                                    path: 'status',
                                    formatter: '.formatOrderStatusState'
                                }" />

                            <ObjectNumber id="numOrderTotal"
                                number="{total}"
                                unit="R$"
                                class="orderTotal" />

                            <Text
                                id="txtOrderDate"
                                text="{
                                    path: 'dataPedido',
                                    targetType: 'any',     
                                    formatter: '.formatOrderDate'
                                }"
                                class="orderDate" />
                        </VBox>

                        <!-- Botão Pagar -->
                       <!-- Botão Pagar (corrigido) -->
                        <Button
                            id="btnOrderPay"
                            text="Pagar"
                            icon="sap-icon://credit-card"
                            type="Accept"
                            press=".onPay"
                            enabled="{
                                path: 'status',
                                targetType: 'any',    
                                formatter: '.isPayEnabled'}" />

                    </HBox>
                </CustomListItem>
            </List>
        </content>

        <!-- Rodapé -->
        <footer>
            <Toolbar id="ordersToolbar">
                <ToolbarSpacer id="ordersToolbarSpacer" />
                <Button id="btnOrdersBack"
                        text="Voltar"
                        press=".onNavBack" />
            </Toolbar>
        </footer>
    </Page>
</mvc:View>