<mvc:View
  controllerName="producao.producao.controller.View1"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core">

  <Page id="page" showHeader="false">

    <VBox id="vboxcabecalho">
    <Toolbar id="toolbarCabecalhoTopoNf" class="cabecalhoTopo sapUiSmallMarginBottom">
            <HBox id="hboxCabecalhoNf" width="100%" alignItems="Center" justifyContent="SpaceBetween">
                <HBox id="hboxEsquerdaNf" alignItems="Center">
                    <Image id="logoTopoNf"
                          src="https://upload.wikimedia.org/wikipedia/commons/5/59/SAP_2011_logo.svg"
                          height="2rem"
                          width="auto"
                          class="sapUiTinyMarginBegin" />
                </HBox>
                <HBox id="hboxCentroNf" width="100%" justifyContent="Center">
                    <Text id="tituloCabecalhoNf"
                          text="Ordens de Produção Abertas - Fabrica de Móveis"
                          class="cabecalhoTexto" />
                </HBox>
                <HBox id="hboxDireitaNf" width="2rem" />
            </HBox>
        </Toolbar>

      <Table
  id="tableOrdensProducao" 
  items="{
    path: '/OrdensProducao',
    parameters: {
      $filter: 'status eq \'pendente\'',
      $orderby: 'createdAt asc, ID asc'
    }
  }"
  mode="SingleSelectMaster"
  class="tabelaComBorda"
  growing="true">

        <columns>
          <Column id="coluna1">
            <Text id="textoColuna1" text="Produto" />
          </Column>
          <Column id="coluna5">
            <Text id="textoColuna5" text="Quantidade" />
          </Column>
          <Column id="coluna2">
            <Text id="textoColuna2" text="Prazo" />
          </Column>
          <Column id="coluna3">
            <Text id="textoColuna3" text="Status" />
          </Column>
          <Column id="coluna4">
            <Text id="textoColuna4" text="Confirmar" />
          </Column>
        </columns>

        <items>
          <ColumnListItem id="tabela" type="Active">
            <cells>
              <Text id="produto" text="{produto_nome}" />
              <Text id="quantidade" text="{quantidade}" />
              <Text id="terminar" text="{fimPrevisto}" />
              <ObjectStatus id="status" text="{status}" state="Warning"/>
              <Button id="botaoPronto" text="Finalizado!" type="Emphasized" press=".onConfirmarProducao" />
            </cells>
          </ColumnListItem>
        </items>
      </Table>
    </VBox>
  </Page>
</mvc:View>
