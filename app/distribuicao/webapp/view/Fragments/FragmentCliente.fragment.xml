<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
  <Dialog id="dialogCliente" title="Confirmação do Cliente" type="Message" draggable="true" resizable="true">
    <Text id = "TituloCliente" text="O pedido chegou corretamente?"/>
    <VBox id = "TituloClientevbox">
      <Button id = "TituloClientePedido" text="✅ Pedido certo" press=".onClienteOk"/>
      <!-- CLIENTE -->
  <Button text="❌ Pedido errado"
  id = "TituloClientePedido2"
          press=".onClienteFalha">
    <customData>
      <core:CustomData key="tipoOcorrencia" value="PEDIDO_ERRADO" writeToDom="false"/>
    </customData>
  </Button>

  <Button text="🧱 Pedido quebrado"
  id = "TituloClientePedido3"
          press=".onClienteFalha">
    <customData>
      <core:CustomData key="tipoOcorrencia" value="PEDIDO_QUEBRADO" writeToDom="false"/>
    </customData>
  </Button>

  <Button text="🤔 Outros"
  id = "TituloClientePedido5"
          press=".onClienteFalha">
    <customData>
      <core:CustomData key="tipoOcorrencia" value="OUTROS" writeToDom="false"/>
    </customData>
  </Button>

    </VBox>
  </Dialog>
</core:FragmentDefinition>
