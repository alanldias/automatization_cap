<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
  <Dialog id="dialogEntregador" title="Confirmação do Entregador" type="Message" draggable="true" resizable="true">
    <Text id = "TituloEntregador" text="Selecione a situação da entrega:"/>
    <VBox id = "TituloEntregadorVbox">
      <Button id = "TituloEntregadorPedido" text="✅ Pedido entregue" press=".onEntregadorConfirmado"/>
      <Button id = "TituloEntregadorCliente" text="🚫 Cliente não estava" press=".onEntregadorFalhaClienteNaoEstava"/>
     <Button text="❓ Cliente não reconhece o pedido"
        id = "TituloEntregadorPedidoErro"
        press=".onEntregadorFalha">
    <customData>
      <core:CustomData key="tipoOcorrencia" value="CLIENTE_DESCONHECE" writeToDom="false"/>
    </customData>
    </Button>
      <Button text="📍 Endereço não encontrado"
              id = "TituloEntregadorPedidoErro2"
              press=".onEntregadorFalha">
        <customData>
          <core:CustomData key="tipoOcorrencia" value="ENDERECO_INVALIDO" writeToDom="false"/>
        </customData>
      </Button> 
    </VBox>
  </Dialog>
</core:FragmentDefinition>
