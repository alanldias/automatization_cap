<mvc:View
    controllerName="distribuicao.controller.ViewEnvioPedido"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    displayBlock="true">
    <Page id="page" title="{i18n>title}" showHeader="true">
    <Button
    id = "botaotela"
    text="Consultar Entrega"
    type="Transparent"
    press=".onIrParaConsultar" />
        <content>

            <Input id="inputCep" placeholder="Cep" />
            <Input id="inputNumero" placeholder="Número" />

                <Button id="idbotao" text="Buscar entrega" press=".onBotaoPress"/>


                <VBox id = "vboxmap">
                <Text id = "idmap" text="Visualização da Rota:" />
                <core:HTML
                id="mapContainer"
                content="&lt;div id='map' style='height:400px;width:100%'&gt;&lt;/div&gt;"/>

            </VBox>
        </content>
    </Page>
</mvc:View>