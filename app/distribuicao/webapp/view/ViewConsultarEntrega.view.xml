<mvc:View
  controllerName="distribuicao.controller.ViewConsultarEntrega"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  displayBlock="true">

  <Page id="pageConsultar" title="Consultar Entrega" showHeader="true">
    <content>

      <!-- Seção de entrada -->
      <VBox
        id="vboxEntradaConsulta"
        class="sapUiSmallMargin sapUiMediumMarginTop"
        renderType="Bare">

        <Input
          id="inputCodigo"
          placeholder="Código de rastreio (ex.: R123456)"
          width="200px"
          class="sapUiSmallMarginBottom" />

        <Button
          id="btnConsultarEntrega"
          text="Buscar Entrega"
          press=".onBotaoPress"
          type="Emphasized"
         width="400px"

          class="sapUiTinyMarginBottom" />
      </VBox>

      <!-- Seção do mapa -->
      <VBox
        id="vboxMapaConsulta"
        class="sapUiSmallMarginTop sapUiMediumMarginBottom sapUiContentPadding">

        <Text
          id="textTituloMapaConsulta"
          text="Visualização da Rota:"
          class="sapUiSmallMarginBottom sapUiSmallMarginTop" />

        <core:HTML
          id="mapContainerEntrega"
          content="&lt;div id='mapConsulta' style='height:400px;width:100%;border:1px solid #ccc;border-radius:8px'&gt;&lt;/div&gt;" />
      </VBox>

    </content>
  </Page>
</mvc:View>
